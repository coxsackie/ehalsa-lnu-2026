rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read all profiles (needed for participant list + matchmaking)
    // Users can only write their OWN profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Presentations: anyone logged in can read, only admin can write
    match /presentations/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // manage via Firebase Console or admin SDK
    }
  }
}
